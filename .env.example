# Example Environment Configuration for Viridian

# Server Configuration
HOST=localhost
PORT=12000

# Security - JWT Secret (REQUIRED IN PRODUCTION)
# Generate a secure secret with: openssl rand -base64 64
# This secret is used to sign JWT tokens - NEVER use the default in production
JWT_SECRET=your-secure-jwt-secret-here

# CORS Configuration
CORS_ORIGIN=http://localhost:12001

# Environment
NODE_ENV=production

# Database — if set, uses PostgreSQL (cloud/RDS); if unset, uses local SQLite
# DATABASE_URL=postgresql://user:password@host:5432/viridian

# Claude CLI path (optional — override auto-detection)
# On Windows, set this to the npm-installed CLI to avoid Bun/antivirus crashes:
# CLAUDE_PATH="C:\Program Files\nodejs\claude.cmd"

# Speech-to-Text
# By default, Viridian uses the browser's Web Speech API (Chrome recommended).
# Cloud providers (Groq, Deepgram, Gladia, AssemblyAI) can be configured in the UI.
