# Example Environment Configuration for Viridian

# Server Configuration
HOST=localhost
PORT=3010

# Security - JWT Secret (REQUIRED IN PRODUCTION)
# Generate a secure secret with: openssl rand -base64 64
# This secret is used to sign JWT tokens - NEVER use the default in production
JWT_SECRET=your-secure-jwt-secret-here

# CORS Configuration
CORS_ORIGIN=http://localhost:5174

# Environment
NODE_ENV=production

# Langfuse Observability (optional — traces all agent interactions)
# Self-host with: docker compose up -d
# Then create a project at http://localhost:3001 to get your keys.
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Langfuse docker-compose secrets (only needed when running docker compose)
LANGFUSE_NEXTAUTH_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production