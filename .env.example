# Example Environment Configuration for Viridian

# Server Configuration
HOST=localhost
PORT=12000

# Security - JWT Secret (REQUIRED IN PRODUCTION)
# Generate a secure secret with: openssl rand -base64 64
# This secret is used to sign JWT tokens - NEVER use the default in production
JWT_SECRET=your-secure-jwt-secret-here

# CORS Configuration
CORS_ORIGIN=http://localhost:12001

# Environment
NODE_ENV=production

# Claude CLI path (optional — override auto-detection)
# On Windows, set this to the npm-installed CLI to avoid Bun/antivirus crashes:
# CLAUDE_PATH="C:\Program Files\nodejs\claude.cmd"

# Langfuse Observability (optional — traces all agent interactions)
# Self-host with: docker compose up -d
# User, project, and API keys are created automatically on first start.
# Login at http://localhost:12003 with the credentials below.
LANGFUSE_BASE_URL=http://localhost:12003
LANGFUSE_PUBLIC_KEY=pk-lf-viridian-dev
LANGFUSE_SECRET_KEY=sk-lf-viridian-dev

# Langfuse docker-compose secrets (only needed when running docker compose)
LANGFUSE_NEXTAUTH_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production

# Langfuse auto-provisioning (user/org/project created on first start)
LANGFUSE_INIT_USER_EMAIL=admin@viridian.local
LANGFUSE_INIT_USER_PASSWORD=viridian-dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_ORG_ID=viri
LANGFUSE_INIT_ORG_NAME=Viri
LANGFUSE_INIT_PROJECT_ID=viridian
LANGFUSE_INIT_PROJECT_NAME=Viridian
