<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" fill="none">
  <defs>
    <linearGradient id="glow" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#34d399"/>
      <stop offset="50%" stop-color="#10b981"/>
      <stop offset="100%" stop-color="#059669"/>
    </linearGradient>
    <linearGradient id="beam" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#34d399" stop-opacity="0"/>
      <stop offset="50%" stop-color="#10b981" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#34d399" stop-opacity="0"/>
    </linearGradient>
    <filter id="soft-glow">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Background circle -->
  <circle cx="64" cy="64" r="60" fill="#0d1117" stroke="url(#glow)" stroke-width="2.5" opacity="0.95"/>

  <!-- Inner ring -->
  <circle cx="64" cy="64" r="48" fill="none" stroke="#10b981" stroke-width="1" opacity="0.2"/>

  <!-- V letterform — angular, geometric -->
  <g filter="url(#soft-glow)">
    <!-- Left stroke of V -->
    <path d="M 36 34 L 64 94" stroke="url(#glow)" stroke-width="7" stroke-linecap="round"/>
    <!-- Right stroke of V -->
    <path d="M 92 34 L 64 94" stroke="url(#glow)" stroke-width="7" stroke-linecap="round"/>
  </g>

  <!-- Code brackets < > flanking the V -->
  <g opacity="0.5">
    <!-- Left bracket < -->
    <path d="M 28 52 L 18 64 L 28 76" stroke="#34d399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <!-- Right bracket > -->
    <path d="M 100 52 L 110 64 L 100 76" stroke="#34d399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </g>

  <!-- Dot at the base of V — the convergence point -->
  <circle cx="64" cy="94" r="4" fill="#34d399" opacity="0.9"/>

  <!-- Small energy dots -->
  <circle cx="64" cy="94" r="7" fill="none" stroke="#34d399" stroke-width="1" opacity="0.3"/>
</svg>
